{
  "name": "dilxhan",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler pages dev public",
    "deploy": "wrangler pages deploy public",
    "db:create": "wrangler d1 create dilxhan-db",
    "db:migrate:local": "wrangler d1 execute dilxhan-db --local --file=./migrations/0001_init.sql",
    "db:seed:local": "wrangler d1 execute dilxhan-db --local --file=./migrations/0002_seed.sql",
    "db:migrate:remote": "wrangler d1 execute dilxhan-db --remote --file=./migrations/0001_init.sql",
    "db:seed:remote": "wrangler d1 execute dilxhan-db --remote --file=./migrations/0002_seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.103.0"
  }
}
